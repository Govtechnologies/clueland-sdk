{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item Definition",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier (e.g., 'mymod:ruby_sword')."
    },
    "texture": {
      "type": "string",
      "description": "Path to the item texture."
    },
    "stack_size": {
      "type": "integer",
      "default": 64
    },
    "tool_type": {
      "type": "string",
      "enum": ["pickaxe", "axe", "shovel", "sword", "none"]
    }
  },
  "required": ["name", "texture"]
}
